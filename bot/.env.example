PORT=5000
  COOKIES=[]

  # إعدادات البوت — انسخ هذا واملأ بياناتك ثم ضعه في Railway كمتغير BOT_CONFIG
  # BOT_CONFIG={"botName":"اسم البوت","prefix":"/","ownerID":"UID_هنا","adminIDs":["UID_هنا"],"timezone":"Africa/Algiers","dashboardPassword":"كلمة_المرور"}

  # ─── GitHub Cookie Sync (اختياري) ──────────────────────────────────────────
  # يتحقق تلقائياً من تغيير account.txt في GitHub ويعيد تسجيل الدخول
  GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
  GITHUB_REPO=owner/repo-name
  GITHUB_COOKIES_FILE=bot/account.txt
  GITHUB_SYNC_INTERVAL_MIN=10
  