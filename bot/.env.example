# ═══════════════════════════════════════════════════════════════
#   Lucifer Bot v3.1.0 — Railway Environment Variables Reference
#   انسخ هذه المتغيرات في Railway → Service → Variables
# ═══════════════════════════════════════════════════════════════

# ── المنفذ (Railway يضبطه تلقائياً — لا تغيّره) ────────────────
PORT=5000

# ── الكوكيز (إلزامي) ───────────────────────────────────────────
# الصق هنا كوكيز فيسبوك بصيغة: c_user=xxx; xs=xxx; sb=xxx; datr=xxx; fr=xxx
COOKIES=c_user=YOUR_USER_ID; xs=YOUR_XS; sb=YOUR_SB; datr=YOUR_DATR; fr=YOUR_FR

# ── الداشبورد ──────────────────────────────────────────────────
SESSION_SECRET=اكتب_هنا_نص_عشوائي_طويل_32_حرف
DASHBOARD_PASSWORD=djamel2025*

# ── إعدادات البوت (اختياري — يأخذ من config.json إذا فارغ) ────
OWNER_ID=61584596371578
TZ=Africa/Algiers

# ── GitHub Cookie Sync (اختياري) ───────────────────────────────
# يسمح للبوت بتحديث الكوكيز تلقائياً من GitHub
# أنشئ Personal Access Token من: github.com/settings/tokens
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO=tarekmrh44-svg/tarek
GITHUB_COOKIES_FILE=bot/account.txt
GITHUB_SYNC_INTERVAL_MIN=10

# ── إعدادات إضافية (اختياري) ───────────────────────────────────
# BOT_CONFIG={"prefix":"/","ownerID":"61584596371578","adminIDs":[]}
